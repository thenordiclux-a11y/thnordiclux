# Supabase (required for products, users, orders, etc. to save and sync)
# Get from: https://app.supabase.com → your project → Settings → API
# Use the "anon" "public" key (long JWT starting with eyJ...), not the publishable key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# On Vercel: add these same two variables in Project → Settings → Environment Variables
# (for Production, Preview, and Development). Redeploy after adding them.
